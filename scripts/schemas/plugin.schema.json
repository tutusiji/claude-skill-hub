{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Coding Tool Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "description", "category"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "minLength": 10 },
    "category": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude-code", "codex", "kimi-code", "opencode", "codewhale"]
      },
      "description": "支持的工具列表，省略则默认全部支持"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "homepage": { "type": "string" },
    "repository": { "type": "string" },
    "license": { "type": "string" }
  }
}
